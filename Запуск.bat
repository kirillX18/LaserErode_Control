@echo off
REM ===================================================================
REM  Запуск «Управление лазерно-эрозионным роботом» (Windows)
REM  Просто дважды кликните по этому файлу.
REM ===================================================================

REM Перейти в папку, где лежит этот .bat (рядом должны быть main.py и edm_app)
cd /d "%~dp0"

echo Проверка зависимостей (PyQt5)...
python -m pip install --quiet PyQt5

echo Запуск программы...
python main.py

REM Не закрывать окно сразу, чтобы было видно сообщения/ошибки
echo.
pause
